{
  "name": "oo-supervisor",
  "version": "0.1.0",
  "private": true,
  "description": "OpenOptimized MCP supervisor sidecar. Reads opencode.json and supervises bundled MCP servers.",
  "type": "module",
  "bin": {
    "oo-supervisor": "dist/cli.js"
  },
  "scripts": {
    "dev": "bun src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build:bin": "bun ./script/build.ts --outdir dist/bin --filename oo-supervisor",
    "build:bin:all": "bun ./script/build.ts --outdir dist/bin --filename oo-supervisor --target bun-darwin-arm64 --target bun-darwin-x64"
  },
  "dependencies": {
    "@oo/mcp-supervisor": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.6.3"
  }
}
