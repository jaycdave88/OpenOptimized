{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenOptimized",
  "version": "0.1.0",
  "identifier": "dev.openoptimized.app",
  "build": {
    "beforeDevCommand": "node ./scripts/tauri-before-dev.mjs",
    "beforeBuildCommand": "node ./scripts/tauri-before-build.mjs",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../app/dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenOptimized",
        "width": 1180,
        "height": 820,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "createUpdaterArtifacts": false,
    "macOS": {
      "entitlements": "./entitlements.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "sidecars/opencode",
      "sidecars/openwork-server",
      "sidecars/opencode-router",
      "sidecars/openwork-orchestrator",
      "sidecars/oo-supervisor",
      "sidecars/chrome-devtools-mcp",
      "sidecars/versions.json"
    ],
    "resources": [
      "../../../resources/opencode.defaults.json",
      "../../../resources/opencode-plugins.json",
      "../../../resources/agents/**/*",
      "../../../resources/agency-agents/**/*",
      "../../../resources/mcp-bin/**/*",
      "../../../resources/sidecar/**/*",
      "../../../resources/flash-moe/**/*",
      "../../../resources/microfish/**/*"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "openoptimized",
          "openwork"
        ]
      }
    },
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://github.com/jaycdave88/OpenOptimized/releases/latest/download/latest.json"
      ]
    }
  }
}
