.turbo/
node_modules/
packages/*/node_modules/
packages/@oo/*/node_modules/
apps/*/node_modules/
.next/
out/
dist/
packages/*/dist/
packages/@oo/*/dist/
apps/*/dist/
tmp/

# OpenOptimized-specific: per-MCP build artifacts are generated by
# scripts/build-mcp-bins.sh from vendor/<repo>/ submodules. Only the
# README stays tracked.
resources/mcp-bin/*/
!resources/mcp-bin/README.md
!resources/mcp-bin/.gitkeep

# Python sidecar staging and agency-agents staging — both generated at
# build time by scripts/stage-python-sidecars.sh and scripts/build-mac.sh
# from the corresponding vendor/ submodules.
resources/sidecar/
resources/agency-agents/

# Local git worktrees
_worktrees/

# Tauri/Rust
packages/desktop/src-tauri/target/
packages/desktop/src-tauri/sidecars/
apps/desktop/src-tauri/target/
apps/desktop/src-tauri/sidecars/

# Env
.env
.env.*
!.env.example

# Bun build artifacts
*.bun-build
apps/server/cli

# pnpm store (created by Docker volume mounts)
.pnpm-store/

# Docker dev workspace (ephemeral mount point)
packaging/docker/workspace/

# OS
.DS_Store

# OpenCode mirror
vendor/opencode/

# OpenCode local deps
.opencode/node_modules/
.opencode/bun.lock

# OpenWork workspace-local artifacts
.opencode/openwork/
.vercel
.env*.local
.claude/*
